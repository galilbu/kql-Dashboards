# ============================================================
# KQL Dashboard — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Azure Entra ID ───────────────────────────────────────────
# Found in: Azure Portal → Entra ID → Overview
TENANT_ID=

# Found in: App Registration → Overview → Application (client) ID
CLIENT_ID=

# Found in: App Registration → Certificates & secrets
# Rotate every 90 days. Use Managed Identity in production instead.
CLIENT_SECRET=

# ── Log Analytics ────────────────────────────────────────────
# Found in: Azure Portal → Log Analytics workspaces → your workspace → Overview
WORKSPACE_ID=

# ── Azure Storage ────────────────────────────────────────────
# Found in: Storage Account → Access keys → Connection string
STORAGE_CONNECTION_STRING=

# ── Azure Key Vault (optional) ────────────────────────────────
# If set, secrets are loaded from Key Vault first, with env var fallback.
# The app identity (Managed Identity or local dev credentials) needs
# "Key Vault Secrets User" role on the vault.
AZURE_KEYVAULT_URL=

# ── App environment ──────────────────────────────────────────
# Set to "development" locally to enable dev token bypass.
# MUST be "production" in all Azure deployments.
ENVIRONMENT=development

# ── Super Admins ────────────────────────────────────────────
# Comma-separated Entra ID user OIDs that have admin on ALL dashboards.
# These users bypass RBAC and see every dashboard.
# Find your OID: Azure Portal → Entra ID → Users → your user → Object ID
SUPER_ADMIN_OIDS=

# ── Local (invite-based) auth ────────────────────────────────
# Used when Entra SSO is not yet configured. Both can run simultaneously.
#
# A random secret for signing local JWTs. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
LOCAL_JWT_SECRET=

# Comma-separated email addresses that get super-admin rights when registering locally.
# These users can generate invite links for others.
# Example: admin@company.com,it@company.com
LOCAL_SUPER_ADMIN_EMAILS=

# ── Email (SMTP) — optional ──────────────────────────────────
# If configured, invite emails are sent automatically.
# Works with Office 365, Gmail, or any SMTP server.
# Example for Office 365:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_USER=noreply@company.com
#   SMTP_PASSWORD=your-app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── MDE (Microsoft Defender for Endpoint) — optional ─────────
# Required for device isolate/release actions.
# If not set, falls back to TENANT_ID/CLIENT_ID/CLIENT_SECRET.
# App registration needs MDE API permissions: Machine.Isolate, Machine.Read.All
MDE_TENANT_ID=
MDE_CLIENT_ID=
MDE_CLIENT_SECRET=

# ── Azure OpenAI — for natural language → KQL generation ─────
# Required for the AI "Describe with AI" feature in dashboard panels.
# Create an Azure OpenAI resource and deploy a model (e.g. gpt-4o).
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# ── Frontend (Vite build-time) ───────────────────────────────
# These are baked into the static bundle at build time.
# Do NOT put secrets here — they will be visible in the browser.
VITE_TENANT_ID=
VITE_CLIENT_ID=
VITE_API_BASE_URL=/api

# ── Dev mode (local only) ─────────────────────────────────
# Set to "true" to bypass MSAL login and use a test user.
# NEVER set this in production builds.
VITE_DEV_MODE=true
VITE_DEV_USER_OID=dev-user-00000000-0000-0000-0000-000000000001
VITE_DEV_USER_NAME=Test Admin